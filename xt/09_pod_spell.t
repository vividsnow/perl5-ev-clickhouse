#!/usr/bin/env perl
# Author hygiene: spell-check POD text. Skips silently when
# Test::Spelling + a working `spell` / `aspell` / `hunspell` isn't
# available, so this only fires under RELEASE_TESTING / xt/.
use strict;
use warnings;
use Test::More;

eval "use Test::Spelling 0.12";
plan skip_all => "Test::Spelling 0.12 required" if $@;

# Locate any spell checker. Test::Spelling auto-picks one, but on
# minimal CI images there may be none — bail cleanly.
my $checker;
for my $bin (qw(hunspell aspell ispell spell)) {
    chomp(my $p = `which $bin 2>/dev/null`);
    if ($p) { $checker = $p; last }
}
plan skip_all => "no spell checker (hunspell/aspell/ispell/spell) in PATH"
    unless $checker;
set_spell_cmd("$checker list") if $checker =~ /hunspell|aspell/;

add_stopwords(<DATA>);
all_pod_files_spelling_ok();

